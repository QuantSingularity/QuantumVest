# Flask Configuration
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=your-secret-key-change-in-production-use-32-chars-min
PORT=5000

# Database Configuration
# SQLite for development (no setup required)
DATABASE_URL=sqlite:///quantumvest_dev.db
# PostgreSQL for production:
# DATABASE_URL=postgresql://quantumvest:password@db:5432/quantumvest

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# API Keys (Optional - app works without them using yfinance)
ALPHA_VANTAGE_API_KEY=
COINAPI_KEY=
YAHOO_FINANCE_API_KEY=

# Web3/Blockchain (Optional)
WEB3_PROVIDER_URL=https://mainnet.infura.io/v3/your-project-id
ETHEREUM_NETWORK=mainnet

# Redis (Optional - caching falls back to SimpleCache if not available)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Email (Optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Security
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30
BCRYPT_LOG_ROUNDS=12

# Feature Flags
ENABLE_PORTFOLIO_OPTIMIZATION=true
ENABLE_REAL_TIME_DATA=true
ENABLE_BLOCKCHAIN_FEATURES=false
ENABLE_ADVANCED_ANALYTICS=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=quantumvest.log

# Model Configuration
MODEL_PATH=../ai_models/
PREDICTION_CACHE_TTL=3600
